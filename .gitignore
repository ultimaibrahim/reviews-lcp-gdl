.ignore/

# Extractos temporales
pdf_extract.txt

# Archivos intermedios de datos (Excel/CSV crudos)
*.xlsx
*.csv

# ─── Caché de Python ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ─── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Editores / IDEs ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Archivos de distribución / build ──────────────────────
dist/
build/
*.zip
*.tar.gz

# ─── Archivos sensibles (nunca subir) ──────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ─── Archivos temporales del sistema ───────────────────────
*.tmp
*.temp
*.bak
